# ── Drosia — environment template ───────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit .env.local.
# Only the NEXT_PUBLIC_* values are safe for the client bundle.

# Supabase (project URL + anon key are public; service-role key is SERVER-ONLY)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server only — never expose

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public contact address for the supporters/partners page (/support "Email us").
# Client-visible. Defaults to info@drosia.eu if unset.
NEXT_PUBLIC_CONTACT_EMAIL=info@drosia.eu

# Public map tiles (default: OpenStreetMap raster tiles)
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>
NEXT_PUBLIC_DEFAULT_MAP_LAT=36.3461
NEXT_PUBLIC_DEFAULT_MAP_LNG=28.1233
NEXT_PUBLIC_DEFAULT_MAP_ZOOM=11

# Resend — sender domain MUST be a verified domain (SPF/DKIM/DMARC) to avoid spam.
# Deliverability is a P0 blocker: authority emails are worthless if they bounce/spam.
RESEND_API_KEY=YOUR_RESEND_KEY
EMAIL_FROM=reports@drosia.eu
EMAIL_VERIFIED_DOMAIN=drosia.eu   # warns at send time if EMAIL_FROM domain differs

# Resend webhook (bounce/complaint → delivery_logs at /api/webhooks/resend).
# Set to the Svix signing secret from the Resend dashboard (whsec_…). If unset,
# the endpoint falls back to Bearer WEBHOOK_SECRET auth.
RESEND_WEBHOOK_SECRET=

# Weekly founder digest (Vercel Cron → /api/cron/weekly-digest, Mondays 08:00 UTC).
# Comma-separated recipients; needs a working Resend setup to actually send.
FOUNDER_EMAILS=
# Vercel injects this as `Authorization: Bearer <CRON_SECRET>` on cron calls.
# If unset, the digest route falls back to WEBHOOK_SECRET.
CRON_SECRET=

# Internal webhook auth (report delivery / bounce webhooks)
WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM

# Image anonymization. Default ("") = DevBlur (whole frame blurred — privacy-safe
# but low utility). Set to "http" to use a SELECTIVE face/plate service that keeps
# the scene sharp; configure its endpoint + key below. Fails closed on error.
ANONYMIZER_PROVIDER=
ANONYMIZER_URL=
ANONYMIZER_API_KEY=

# Admin board (operator tool). Set a password to enable sign-in; the session is
# an HMAC cookie signed with ADMIN_SESSION_SECRET (falls back to WEBHOOK_SECRET).
# REQUIRED in production: with neither set, the app refuses to sign sessions
# (a known/default secret would let anyone forge an admin cookie → takeover).
ADMIN_PASSWORD=CHANGE_ME
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM

# Geofencing. STRICT by default: reports outside every active country are rejected
# (HTTP 422 OUT_OF_BOUNDS). Set to "true" ONLY for cross-country testing; relaxed
# mode accepts unrouted reports for admin review. NEVER set in production.
GEOFENCE_RELAXED=

# Set to "true" only if the app is actually served behind Cloudflare, so that
# cf-connecting-ip is trustworthy for rate limiting. Otherwise leave empty —
# trusting it when not behind CF lets clients spoof their IP and bypass limits.
TRUST_CF_HEADER=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@drosia.eu

# Geocoding (Nominatim default; provider-swappable via lib/providers/geocoding.ts)
GEOCODER_PROVIDER=nominatim
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=Drosia/0.1 (hello@drosia.eu)

# Seeding — seeds ONLY run when this is exactly "dev". Never set in production.
SEED_ENV=
