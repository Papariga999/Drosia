# ── Drosia — environment template ───────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit .env.local.
# Only the NEXT_PUBLIC_* values are safe for the client bundle.

# Supabase (project URL + anon key are public; service-role key is SERVER-ONLY)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # server only — never expose

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — sender domain MUST be a verified domain (SPF/DKIM/DMARC) to avoid spam.
# Deliverability is a P0 blocker: authority emails are worthless if they bounce/spam.
RESEND_API_KEY=YOUR_RESEND_KEY
EMAIL_FROM=reports@drosia.eu
EMAIL_VERIFIED_DOMAIN=drosia.eu   # warns at send time if EMAIL_FROM domain differs

# Internal webhook auth (report delivery / bounce webhooks)
WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM

# Admin board (operator tool). Set a password to enable sign-in; the session is
# an HMAC cookie signed with ADMIN_SESSION_SECRET (falls back to WEBHOOK_SECRET).
ADMIN_PASSWORD=CHANGE_ME
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@drosia.eu

# Geocoding (Nominatim default; provider-swappable via lib/providers/geocoding.ts)
GEOCODER_PROVIDER=nominatim
GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=Drosia/0.1 (hello@drosia.eu)

# Seeding — seeds ONLY run when this is exactly "dev". Never set in production.
SEED_ENV=
